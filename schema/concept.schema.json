{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://curricula.live/schema/concept.schema.json",
  "title": "curricula.live concept",
  "type": "object",
  "additionalProperties": false,
  "required": ["slug", "label", "description", "metadata"],
  "properties": {
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "description": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  }
}
