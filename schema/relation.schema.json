{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://curricula.live/schema/relation.schema.json",
  "title": "curricula.live relation",
  "type": "object",
  "additionalProperties": false,
  "required": ["source", "target", "type", "metadata"],
  "properties": {
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
    },
    "target": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "metadata": {
      "type": "object"
    }
  }
}
